<Window x:Class="CopyEverywhere.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CopyEverywhere"
        Width="420" Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="16">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="CopyEverywhere" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Cross-device clipboard &amp; file transfer" Foreground="Gray" FontSize="11" Margin="0,0,0,16"/>

            <!-- Server Configuration -->
            <TextBlock Text="Server Configuration" Style="{StaticResource SectionHeader}"/>

            <TextBlock Text="Host URL" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="HostUrlTextBox"
                     Margin="0,0,0,12"
                     Padding="6,4"
                     Text="{Binding HostUrl, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Access Token" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="AccessTokenBox"
                         Margin="0,0,0,16"
                         Padding="6,4"
                         PasswordChanged="AccessTokenBox_PasswordChanged"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button x:Name="SaveButton"
                        Content="Save"
                        Width="80" Height="30"
                        Margin="0,0,8,0"
                        Click="SaveButton_Click"/>
                <Button x:Name="TestConnectionButton"
                        Content="Test Connection"
                        Width="120" Height="30"
                        Click="TestConnectionButton_Click"/>
            </StackPanel>

            <!-- Status -->
            <Border x:Name="StatusBorder"
                    Visibility="Collapsed"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <TextBlock x:Name="StatusText"
                           TextWrapping="Wrap"
                           FontSize="12"/>
            </Border>

            <!-- Separator -->
            <Separator Margin="0,4,0,16"/>

            <!-- Send Clipboard Section -->
            <StackPanel x:Name="ClipboardPanel" Visibility="Collapsed">
                <TextBlock Text="Send Clipboard" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Clipboard Preview" Style="{StaticResource FieldLabel}"/>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                        MinHeight="60" MaxHeight="100">
                    <TextBlock x:Name="ClipboardPreviewText"
                               Text="(empty)"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               FontSize="12"/>
                </Border>

                <Button x:Name="SendClipboardButton"
                        Content="Send Clipboard"
                        Width="130" Height="30"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,8"
                        Click="SendClipboardButton_Click"/>

                <Border x:Name="SendStatusBorder"
                        Visibility="Collapsed"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="SendStatusText"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </Border>

                <Separator Margin="0,4,0,16"/>

                <!-- Receive Clipboard Section -->
                <TextBlock Text="Receive Clipboard" Style="{StaticResource SectionHeader}"/>

                <Button x:Name="ReceiveLatestButton"
                        Content="Receive Latest"
                        Width="130" Height="30"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,12"
                        Click="ReceiveLatestButton_Click"/>

                <TextBlock Text="Or enter Clip ID" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox x:Name="ClipIdTextBox"
                             Width="120"
                             Padding="6,4"
                             MaxLength="6"
                             Margin="0,0,8,0"/>
                    <Button x:Name="FetchClipButton"
                            Content="Fetch"
                            Width="70" Height="28"
                            Click="FetchClipButton_Click"/>
                </StackPanel>

                <Border x:Name="ReceiveStatusBorder"
                        Visibility="Collapsed"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="ReceiveStatusText"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </Border>
            </StackPanel>

            <!-- Not configured placeholder -->
            <TextBlock x:Name="MainPanelPlaceholder"
                       Text="Configure server connection above to get started."
                       Foreground="Gray"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
