<Window x:Class="CopyEverywhere.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CopyEverywhere"
        Width="420" Height="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.InputBindings>
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Paste}"/>
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Paste}" Executed="PasteCommand_Executed"/>
    </Window.CommandBindings>

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid AllowDrop="True"
          DragEnter="Window_DragEnter"
          DragOver="Window_DragOver"
          DragLeave="Window_DragLeave"
          Drop="Window_Drop">

        <!-- In-window toast banner -->
        <Border x:Name="ToastBanner"
                Visibility="Collapsed"
                Panel.ZIndex="200"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Background="#DCFCE7"
                Padding="12,8"
                Margin="0">
            <TextBlock x:Name="ToastBannerText"
                       FontSize="13"
                       Foreground="#15803D"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Drop overlay -->
        <Border x:Name="DropOverlay"
                Visibility="Collapsed"
                Background="#C0FFFFFF"
                Panel.ZIndex="100">
            <Border BorderBrush="#3B82F6" BorderThickness="3"
                    CornerRadius="8" Margin="16">
                <TextBlock Text="Drop to send"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="#3B82F6"/>
            </Border>
        </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="16">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="CopyEverywhere" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Cross-device clipboard &amp; file transfer" Foreground="Gray" FontSize="11" Margin="0,0,0,16"/>

            <!-- Server Configuration -->
            <TextBlock Text="Server Configuration" Style="{StaticResource SectionHeader}"/>

            <!-- Discovered Servers -->
            <TextBlock Text="Discovered Servers" Style="{StaticResource FieldLabel}" FontWeight="SemiBold"/>
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8"
                    MinHeight="40" MaxHeight="160">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DiscoveredServersPanel">
                        <TextBlock Text="Scanning for servers on LAN..."
                                   Foreground="Gray"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,10"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <TextBlock Text="Host URL (manual)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="HostUrlTextBox"
                     Margin="0,0,0,12"
                     Padding="6,4"
                     Text="{Binding HostUrl, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel x:Name="AccessTokenPanel">
                <TextBlock x:Name="AccessTokenLabel" Text="Access Token" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="AccessTokenBox"
                             Margin="0,0,0,16"
                             Padding="6,4"
                             PasswordChanged="AccessTokenBox_PasswordChanged"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button x:Name="SaveButton"
                        Content="Save"
                        Width="80" Height="30"
                        Margin="0,0,8,0"
                        Click="SaveButton_Click"/>
                <Button x:Name="TestConnectionButton"
                        Content="Test Connection"
                        Width="120" Height="30"
                        Click="TestConnectionButton_Click"/>
            </StackPanel>

            <!-- Status -->
            <Border x:Name="StatusBorder"
                    Visibility="Collapsed"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <TextBlock x:Name="StatusText"
                           TextWrapping="Wrap"
                           FontSize="12"/>
            </Border>

            <!-- Device Info (read-only, shown when registered) -->
            <StackPanel x:Name="DeviceInfoPanel" Visibility="Collapsed" Margin="0,0,0,12">
                <TextBlock Text="Registered Device" Style="{StaticResource FieldLabel}" FontWeight="SemiBold"/>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="8,6" Background="#F9F9F9">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="Name: " FontSize="12" Foreground="Gray"/>
                            <TextBlock x:Name="DeviceNameText" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ID: " FontSize="12" Foreground="Gray"/>
                            <TextBlock x:Name="DeviceIdText" FontSize="12" FontFamily="Consolas"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border x:Name="ReceiverStatusBorder"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,0,0,12"
                    Background="#F3F4F6">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock x:Name="ReceiverStatusIcon"
                                   Text="&#x25CF;"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="Gray"
                                   Margin="0,0,6,0"/>
                        <TextBlock x:Name="ReceiverStatusText"
                                   Text="Receiver Status: Disconnected"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="#4B5563"/>
                    </StackPanel>
                    <TextBlock x:Name="ReceiverStatusDetailText"
                               Text="Save a server URL to bring the receiver channel online."
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="#4B5563"/>
                </StackPanel>
            </Border>

            <!-- Target Device Selector -->
            <TextBlock Text="Delivery Target" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="TargetDeviceComboBox"
                      Margin="0,0,0,12"
                      Padding="6,4"
                      SelectionChanged="TargetDeviceComboBox_SelectionChanged"/>

            <Border x:Name="TargetDeviceStatusBorder"
                    Visibility="Collapsed"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="TargetDeviceStatusText"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="TargetDeviceStatusDetailText"
                               FontSize="11"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Floating Ball Toggle -->
            <CheckBox x:Name="FloatingBallCheckBox"
                      Content="Show floating drop target"
                      IsChecked="True"
                      Margin="0,0,0,12"
                      Checked="FloatingBallCheckBox_Changed"
                      Unchecked="FloatingBallCheckBox_Changed"/>

            <!-- Separator -->
            <Separator Margin="0,4,0,16"/>

            <!-- Transfer Mode -->
            <TextBlock Text="Transfer Mode" Style="{StaticResource SectionHeader}"/>
            <ComboBox x:Name="TransferModeComboBox"
                      Margin="0,0,0,12"
                      Padding="6,4"
                      SelectionChanged="TransferModeComboBox_SelectionChanged">
                <ComboBoxItem Content="LAN Server" Tag="LanServer"/>
                <ComboBoxItem Content="Bluetooth Direct" Tag="Bluetooth"/>
            </ComboBox>

            <!-- Bluetooth Section (hidden by default) -->
            <StackPanel x:Name="BluetoothSection" Visibility="Collapsed">
                <!-- Connection Status -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock x:Name="BtStatusIcon" Text="&#x25CF;" FontSize="14" VerticalAlignment="Center"
                               Foreground="Gray" Margin="0,0,6,0"/>
                    <TextBlock x:Name="BtStatusText" Text="Disconnected" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Bluetooth Error -->
                <Border x:Name="BtErrorBorder" Visibility="Collapsed" CornerRadius="4" Padding="10,8" Margin="0,0,0,8"
                        Background="#FEE2E2">
                    <TextBlock x:Name="BtErrorText" TextWrapping="Wrap" FontSize="12" Foreground="#B91C1C"/>
                </Border>

                <!-- Paired Devices -->
                <TextBlock Text="Paired Devices" Style="{StaticResource FieldLabel}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8"
                        MinHeight="40" MaxHeight="200">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PairedDevicesPanel">
                            <TextBlock x:Name="NoPairedDevicesText"
                                       Text="No paired devices. Scan to find nearby devices."
                                       Foreground="Gray" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,10,0,10"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Scan Section -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Scan Nearby Devices" Style="{StaticResource FieldLabel}" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button x:Name="BtScanButton" Content="Scan" Width="70" Height="26" FontSize="11"
                            Click="BtScanButton_Click"/>
                </StackPanel>

                <!-- Scanning indicator -->
                <StackPanel x:Name="BtScanningPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,8">
                    <TextBlock Text="Scanning for CopyEverywhere devices..." FontSize="11" Foreground="Gray"/>
                </StackPanel>

                <!-- Scan Error -->
                <TextBlock x:Name="BtScanErrorText" Visibility="Collapsed" FontSize="11" Foreground="#B91C1C" Margin="0,0,0,8"/>

                <!-- Discovered Devices -->
                <Border x:Name="BtDiscoveredBorder" Visibility="Collapsed"
                        BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8"
                        MaxHeight="200">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="BtDiscoveredPanel"/>
                    </ScrollViewer>
                </Border>

                <!-- Bluetooth Receive Progress -->
                <StackPanel x:Name="BtReceiveProgressPanel" Visibility="Collapsed" Margin="0,0,0,8">
                    <ProgressBar x:Name="BtReceiveProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"/>
                    <TextBlock x:Name="BtReceiveProgressText" FontSize="11" Foreground="Gray" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Embedded Server Section -->
            <Separator Margin="0,4,0,16"/>
            <TextBlock Text="Embedded Server" Style="{StaticResource SectionHeader}"/>

            <CheckBox x:Name="ServerEnabledCheckBox"
                      Content="Enable embedded server"
                      Margin="0,0,0,8"
                      Checked="ServerEnabledCheckBox_Changed"
                      Unchecked="ServerEnabledCheckBox_Changed"/>

            <StackPanel x:Name="ServerConfigSection" Visibility="Collapsed">
                <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ServerPortBox" Margin="0,0,0,8" Padding="6,4"/>

                <TextBlock Text="Bind Address" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ServerBindAddressBox" Margin="0,0,0,8" Padding="6,4"/>

                <TextBlock Text="Storage Path" Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ServerStoragePathBox" Grid.Column="0" Padding="6,4"/>
                    <Button x:Name="ServerStorageBrowseButton" Grid.Column="1" Content="Browse"
                            Width="60" Margin="4,0,0,0" Click="ServerStorageBrowseButton_Click"/>
                </Grid>

                <TextBlock Text="TTL (hours)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ServerTtlBox" Margin="0,0,0,8" Padding="6,4"/>

                <TextBlock Text="Max Clip Size (MB)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ServerMaxClipSizeBox" Margin="0,0,0,8" Padding="6,4"/>

                <CheckBox x:Name="ServerAuthCheckBox"
                          Content="Require authentication"
                          Margin="0,0,0,8"
                          Checked="ServerAuthCheckBox_Changed"
                          Unchecked="ServerAuthCheckBox_Changed"/>

                <StackPanel x:Name="ServerTokenPanel" Visibility="Collapsed" Margin="0,0,0,8">
                    <TextBlock Text="Server Access Token" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="ServerAccessTokenBox" Padding="6,4"
                                 PasswordChanged="ServerAccessTokenBox_PasswordChanged"/>
                </StackPanel>

                <CheckBox x:Name="ServerAutoStartCheckBox"
                          Content="Auto-start server on launch"
                          Margin="0,0,0,12"/>

                <Button x:Name="ServerApplyButton"
                        Content="Apply &amp; Restart Server"
                        Padding="8,4" Margin="0,0,0,8"
                        Click="ServerApplyButton_Click"/>
            </StackPanel>

            <!-- Server Management Panel (visible when server is enabled) -->
            <StackPanel x:Name="ServerManagementSection" Visibility="Collapsed">
                <Separator Margin="0,4,0,16"/>
                <TextBlock Text="Server Management" Style="{StaticResource SectionHeader}"/>

                <!-- Status indicator -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock x:Name="ServerStatusDot" Text="&#x25CF;" FontSize="14" VerticalAlignment="Center"
                               Foreground="Gray" Margin="0,0,6,0"/>
                    <TextBlock x:Name="ServerStatusText" Text="Disabled" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Control buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="ServerStartButton" Content="Start" Width="70" Height="26" FontSize="11"
                            Margin="0,0,6,0" Click="ServerStartButton_Click"/>
                    <Button x:Name="ServerStopButton" Content="Stop" Width="70" Height="26" FontSize="11"
                            Margin="0,0,6,0" Click="ServerStopButton_Click" Visibility="Collapsed"/>
                    <Button x:Name="ServerRestartButton" Content="Restart" Width="70" Height="26" FontSize="11"
                            Click="ServerRestartButton_Click" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Storage stats -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Storage" Style="{StaticResource FieldLabel}" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ServerStorageUsedText" FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                    <TextBlock x:Name="ServerStoragePathText" FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Connected devices -->
                <TextBlock Text="Connected Devices" Style="{StaticResource FieldLabel}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8"
                        MinHeight="30" MaxHeight="120">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ServerDevicesPanel">
                            <TextBlock x:Name="NoServerDevicesText"
                                       Text="No devices connected"
                                       Foreground="Gray" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,6,0,6"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Log viewer -->
                <TextBlock Text="Server Logs" Style="{StaticResource FieldLabel}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8"
                        MaxHeight="150">
                    <ScrollViewer x:Name="ServerLogScrollViewer" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ServerLogText" FontSize="10" FontFamily="Consolas"
                                   Padding="6,4" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Separator before main content -->
            <Separator Margin="0,4,0,16"/>

            <!-- Send Clipboard Section -->
            <StackPanel x:Name="ClipboardPanel" Visibility="Collapsed">
                <TextBlock Text="Send Clipboard" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Clipboard Preview" Style="{StaticResource FieldLabel}"/>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                        MinHeight="60" MaxHeight="100">
                    <TextBlock x:Name="ClipboardPreviewText"
                               Text="(empty)"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               FontSize="12"/>
                </Border>

                <Button x:Name="SendClipboardButton"
                        Content="Send Clipboard"
                        Width="130" Height="30"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,8"
                        Click="SendClipboardButton_Click"/>

                <Border x:Name="SendStatusBorder"
                        Visibility="Collapsed"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="SendStatusText"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </Border>

                <Separator Margin="0,4,0,16"/>

                <!-- Receive Clipboard Section -->
                <TextBlock Text="Receive Clipboard" Style="{StaticResource SectionHeader}"/>

                <Button x:Name="ReceiveLatestButton"
                        Content="Receive Latest"
                        Width="130" Height="30"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,12"
                        Click="ReceiveLatestButton_Click"/>

                <TextBlock Text="Or enter Clip ID" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox x:Name="ClipIdTextBox"
                             Width="120"
                             Padding="6,4"
                             MaxLength="6"
                             Margin="0,0,8,0"/>
                    <Button x:Name="FetchClipButton"
                            Content="Fetch"
                            Width="70" Height="28"
                            Click="FetchClipButton_Click"/>
                </StackPanel>

                <Border x:Name="ReceiveStatusBorder"
                        Visibility="Collapsed"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="ReceiveStatusText"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </Border>

                <Separator Margin="0,4,0,16"/>

                <!-- Send File Section -->
                <TextBlock Text="Send File" Style="{StaticResource SectionHeader}"/>

                <Border x:Name="DropZoneBorder"
                        BorderBrush="Gray" BorderThickness="2"
                        CornerRadius="4" Padding="16" Margin="0,0,0,8"
                        MinHeight="80" AllowDrop="True"
                        Drop="DropZone_Drop" DragOver="DropZone_DragOver"
                        DragLeave="DropZone_DragLeave"
                        Background="Transparent">
                    <TextBlock x:Name="DropZoneText"
                               Text="Drop a file here"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Gray" FontSize="13"/>
                </Border>

                <Button x:Name="ChooseFileButton"
                        Content="Choose File"
                        Width="100" Height="30"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,8"
                        Click="ChooseFileButton_Click"/>

                <!-- Upload progress -->
                <StackPanel x:Name="UploadProgressPanel" Visibility="Collapsed" Margin="0,0,0,8">
                    <ProgressBar x:Name="UploadProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"/>
                    <TextBlock x:Name="UploadProgressText" FontSize="11" Foreground="Gray" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Pause/Resume for chunked upload -->
                <StackPanel x:Name="ChunkedControlPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,8">
                    <Button x:Name="PauseUploadButton" Content="Pause" Width="80" Height="28" Margin="0,0,8,0" Click="PauseUploadButton_Click"/>
                    <Button x:Name="ResumeUploadButton" Content="Resume" Width="80" Height="28" Visibility="Collapsed" Click="ResumeUploadButton_Click"/>
                </StackPanel>

                <Border x:Name="FileUploadStatusBorder"
                        Visibility="Collapsed"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="FileUploadStatusText"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </Border>

                <Separator Margin="0,4,0,16"/>

                <!-- Download File Section -->
                <TextBlock Text="Download File" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Enter Clip ID" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox x:Name="DownloadClipIdTextBox"
                             Width="120"
                             Padding="6,4"
                             MaxLength="6"
                             Margin="0,0,8,0"/>
                    <Button x:Name="LookupClipButton"
                            Content="Lookup"
                            Width="70" Height="28"
                            Click="LookupClipButton_Click"/>
                </StackPanel>

                <!-- File metadata display -->
                <Border x:Name="FileMetadataBorder"
                        Visibility="Collapsed"
                        BorderBrush="LightGray" BorderThickness="1"
                        CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock x:Name="FileMetadataText" TextWrapping="Wrap" FontSize="12"/>
                        <Button x:Name="DownloadFileButton"
                                Content="Download"
                                Width="90" Height="28"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Click="DownloadFileButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- Download progress -->
                <StackPanel x:Name="DownloadProgressPanel" Visibility="Collapsed" Margin="0,0,0,8">
                    <ProgressBar x:Name="DownloadProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"/>
                    <TextBlock x:Name="DownloadProgressText" FontSize="11" Foreground="Gray" Margin="0,4,0,0"/>
                </StackPanel>

                <Border x:Name="DownloadStatusBorder"
                        Visibility="Collapsed"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="DownloadStatusText"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </Border>

                <Separator Margin="0,4,0,16"/>

                <!-- Server Queue Section (LAN mode) -->
                <StackPanel x:Name="LanQueueSection">
                    <TextBlock Text="Queue Mode &amp; Recovery" Style="{StaticResource SectionHeader}"/>

                    <Border x:Name="LanReceiverStatusBorder"
                            Background="#F3F4F6"
                            CornerRadius="4"
                            Padding="8"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="LanReceiverStatusDot"
                                         Width="8"
                                         Height="8"
                                         Fill="Gray"
                                         Margin="0,0,6,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="LanReceiverStatusLabel"
                                           Text="Disconnected"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="#4B5563"/>
                            </StackPanel>
                            <TextBlock x:Name="LanReceiverStatusDetailText"
                                       Text="Save a server URL to bring the receiver channel online."
                                       FontSize="11"
                                       Foreground="#4B5563"
                                       Margin="14,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="QueueScrollViewer" MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <StackPanel x:Name="QueueListPanel">
                            <TextBlock x:Name="QueueEmptyText"
                                       Text="Queue is empty — copy something and click the icon."
                                       Foreground="Gray"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,8"/>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <!-- Bluetooth Status Section (BT mode) -->
                <StackPanel x:Name="BtStatusSection" Visibility="Collapsed">
                    <TextBlock Text="Bluetooth" Style="{StaticResource SectionHeader}"/>

                    <Border x:Name="BtStatusBadge"
                            Background="#F0F0F0"
                            CornerRadius="4"
                            Padding="8"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="BtStatusDot" Width="8" Height="8" Fill="Gray" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="BtStatusLabel" Text="Disconnected" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="BtConnectedDeviceText"
                               FontSize="12"
                               Foreground="#0066CC"
                               Margin="0,0,0,8"
                               Visibility="Collapsed"/>

                    <TextBlock x:Name="BtPairHintText"
                               Text="Pair a device in the Bluetooth section above to send and receive."
                               Foreground="Gray"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,8"
                               Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>

            <!-- Not configured placeholder -->
            <TextBlock x:Name="MainPanelPlaceholder"
                       Text="Configure server connection above to get started."
                       Foreground="Gray"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
    </Grid>
</Window>
