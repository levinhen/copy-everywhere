<Window x:Class="CopyEverywhere.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CopyEverywhere"
        Width="420" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="CopyEverywhere" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Cross-device clipboard &amp; file transfer" Foreground="Gray" FontSize="11" Margin="0,0,0,16"/>

            <!-- Server Configuration -->
            <TextBlock Text="Server Configuration" Style="{StaticResource SectionHeader}"/>

            <TextBlock Text="Host URL" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="HostUrlTextBox"
                     Margin="0,0,0,12"
                     Padding="6,4"
                     Text="{Binding HostUrl, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Access Token" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="AccessTokenBox"
                         Margin="0,0,0,16"
                         Padding="6,4"
                         PasswordChanged="AccessTokenBox_PasswordChanged"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button x:Name="SaveButton"
                        Content="Save"
                        Width="80" Height="30"
                        Margin="0,0,8,0"
                        Click="SaveButton_Click"/>
                <Button x:Name="TestConnectionButton"
                        Content="Test Connection"
                        Width="120" Height="30"
                        Click="TestConnectionButton_Click"/>
            </StackPanel>

            <!-- Status -->
            <Border x:Name="StatusBorder"
                    Visibility="Collapsed"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <TextBlock x:Name="StatusText"
                           TextWrapping="Wrap"
                           FontSize="12"/>
            </Border>

            <!-- Separator -->
            <Separator Margin="0,4,0,16"/>

            <!-- Main Panel Placeholder (for future stories) -->
            <TextBlock x:Name="MainPanelPlaceholder"
                       Text="Configure server connection above to get started."
                       Foreground="Gray"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
